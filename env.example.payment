# Payment System Environment Variables

# Stripe Configuration (Required)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Fortnox Configuration (Required)
FORTNOX_CLIENT_SECRET="your_fortnox_client_secret_here"
FORTNOX_ACCESS_TOKEN="your_fortnox_access_token_here"

# Application Base URL (Required)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Demo: bypass payment walls (no Fortnox invoices; company subscription checks pass).
# Use only temporarily. Client needs NEXT_PUBLIC_ — restart dev server after changing.
# NEXT_PUBLIC_DISABLE_PAYMENTS=true
# Optional server-only duplicate for scripts/cron:
# DISABLE_PAYMENTS=true

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace all placeholder values with your actual API keys
# 3. Never commit .env.local to version control

# Stripe Setup:
# 1. Create account at https://stripe.com
# 2. Get API keys from Dashboard > Developers > API keys
# 3. Set up webhook endpoint at Dashboard > Developers > Webhooks
#    - Endpoint URL: https://yourdomain.com/api/webhooks/stripe
#    - Events to send: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed

# Fortnox Setup:
# 1. Create account at https://fortnox.se
# 2. Go to Utvecklare > Mina appar
# 3. Create new app and get Client Secret
# 4. Generate Access Token for your company
