// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  personalNumber String?
  role          String    @default("EMPLOYEE") // UserRole as string
  companyId     String?
  
  // BankID verification (required for ID06)
  bankIdVerified Boolean  @default(false)
  bankIdVerifiedAt DateTime?
  
  // ID06 eligibility
  id06Eligible Boolean @default(false)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  company       Company?  @relation(fields: [companyId], references: [id])
  enrollments   Enrollment[]
  progress      Progress[]
  certificates  Certificate[]
  answers       Answer[]
  apvSubmissions APVSubmission[]
  giftedEnrollments Enrollment[] @relation("GiftedEnrollments")
  payments      Payment[]
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String
  price       Float
  image       String?
  duration    Int       // in minutes
  category    String
  isPublished Boolean   @default(false)
  passingScore Int      @default(80) // Minimum percentage to pass (0-100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  lessons     Lesson[]
  enrollments Enrollment[]
  certificates Certificate[]
  coursePurchases CoursePurchase[]
  invoiceItems InvoiceItem[]
  apvSubmissions APVSubmission[]
  payments    Payment[]
}

model Lesson {
  id          String    @id @default(cuid())
  title       String
  type        String    // 'video', 'image', 'text', 'question'
  content     String?   // For text content (markdown)
  videoUrl    String?   // For video files
  imageUrl    String?   // For images
  order       Int
  courseId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[] // For question type lessons
  progress    Progress[]
}

model Question {
  id              String    @id @default(cuid())
  question        String
  type            String    // 'multiple_choice', 'true_false', 'text'
  options         String    // JSON string for multiple choice questions
  correctAnswer   String
  explanation     String?
  image           String?
  lessonId        String
  order           Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  answers         Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String
  isCorrect  Boolean
  answeredAt DateTime @default(now())
  
  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, questionId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  coursePurchaseId String?
  enrolledAt DateTime @default(now())
  completedAt DateTime?
  passed    Boolean  @default(false) // Whether user passed the course
  finalScore Int?    // Final score percentage (0-100)
  totalQuestions Int @default(0) // Total questions in course
  correctAnswers Int @default(0) // Total correct answers
  
  // Gift tracking
  isGift    Boolean  @default(false) // Whether this enrollment is a gift
  giftedBy  String?  // Admin user ID who gifted this course
  giftedAt  DateTime? // When the gift was given
  giftReason String? // Optional reason for the gift
  
  // Payment tracking
  isPaid    Boolean  @default(false) // Whether payment is confirmed
  paidAt    DateTime? // When payment was confirmed
  stripePaymentId String? // Stripe payment intent ID
  stripeCustomerId String? // Stripe customer ID
  fortnoxInvoiceId String? // Fortnox invoice ID
  paymentAmount Float? // Amount paid in SEK
  paymentMethod String? // card, swish, klarna, etc.
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coursePurchase CoursePurchase? @relation(fields: [coursePurchaseId], references: [id], onDelete: Cascade)
  giftedByUser User? @relation("GiftedEnrollments", fields: [giftedBy], references: [id], onDelete: SetNull)
  payment   Payment?
  
  @@unique([userId, courseId])
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  completedAt DateTime?
  score     Int?     // Score for this lesson (0-100)
  attempts  Int      @default(0) // Number of attempts
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
}

model Company {
  id                String    @id @default(cuid())
  organizationNumber String   @unique
  name              String
  contactPerson     String
  email             String
  phone             String
  address           String
  
  // Company verification (no BankID needed)
  verified          Boolean   @default(false)
  verifiedAt        DateTime?
  verificationMethod String @default("BUSINESS_REGISTRATION") // VerificationMethod as string
  
  // Subscription and payment
  plan              String    @default("STANDARD") // STANDARD
  planPrice         Float     @default(1500) // Annual price in SEK
  planStartDate     DateTime  @default(now())
  planEndDate       DateTime?
  paymentStatus     String    @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  employees         User[]
  coursePurchases   CoursePurchase[]
  invoices          Invoice[]
  invitations       Invitation[]
  paymentLogs       PaymentLog[]
  payments          Payment[]
}

model CoursePurchase {
  id           String   @id @default(cuid())
  companyId    String
  courseId     String
  quantity     Int
  pricePerUnit Float
  totalAmount  Float
  purchasedAt  DateTime @default(now())
  
  // Relations
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
}

model Certificate {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  certificateNumber String @unique
  
  // ID06 integration
  id06Verified Boolean @default(false)
  id06CertificateId String?
  id06RegisteredAt DateTime?
  
  // APV submission tracking
  apvSubmitted Boolean @default(false)
  apvSubmittedAt DateTime?
  apvSubmissionId String? // Reference to APVSubmission
  
  issuedAt  DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  apvSubmission APVSubmission?
  
  @@unique([userId, courseId])
}

// New model for APV submissions
model APVSubmission {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  certificateId String? @unique
  
  // User information for APV
  fullName  String
  personalNumber String?
  address   String?
  postalCode String?
  city      String?
  phone     String?
  
  // Course completion verification
  courseTitle String
  completionDate DateTime
  finalScore Int
  passingScore Int
  totalQuestions Int
  correctAnswers Int
  timeTaken Int? // in minutes
  
  // User answers data (JSON string containing all answers with correct answers)
  answersData String // JSON string: [{questionId, question, userAnswer, correctAnswer, isCorrect, options}]
  
  // Submission status
  status    String @default("PENDING") // PENDING, APPROVED, REJECTED, ID06_REGISTERED
  submittedAt DateTime @default(now())
  reviewedAt DateTime?
  reviewedBy String? // Admin who reviewed
  reviewNotes String?
  
  // ID06 registration
  id06Registered Boolean @default(false)
  id06RegisteredAt DateTime?
  id06CertificateId String?
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificate Certificate? @relation(fields: [certificateId], references: [id])
  
  @@unique([userId, courseId])
}

model Invoice {
  id           String        @id @default(cuid())
  companyId    String
  invoiceNumber String       @unique
  amount       Float
  currency     String        @default("SEK")
  dueDate      DateTime
  status       String        @default("PENDING") // InvoiceStatus as string
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  
  // Relations
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items        InvoiceItem[]
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  courseId  String
  quantity  Int
  price     Float
  total     Float
  
  // Relations
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  userId          String?
  companyId       String?
  courseId        String?
  enrollmentId    String?  @unique
  
  // Stripe data
  stripePaymentId String   @unique
  stripeCustomerId String?
  stripeSessionId String?  @unique
  
  // Payment details
  amount          Float
  currency        String   @default("SEK")
  status          String   // succeeded, failed, pending, refunded
  paymentMethod   String?  // card, swish, klarna, etc.
  
  // Fortnox integration
  fortnoxInvoiceId String?
  fortnoxCustomerId String?
  fortnoxSynced   Boolean  @default(false)
  fortnoxSyncedAt DateTime?
  
  // Metadata
  metadata        String?  // JSON string for additional data
  failureReason   String?  // If payment failed
  refundReason    String?  // If payment was refunded
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollment      Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model PaymentLog {
  id              String   @id @default(cuid())
  companyId       String?
  stripePaymentId String   @unique
  amount          Float
  currency        String   @default("SEK")
  status          String   // succeeded, failed, pending
  paymentMethod   String?  // card, sepa, swish, invoice
  metadata        String?  // JSON string
  createdAt       DateTime @default(now())
  
  // Relations
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invitation {
  id               String   @id @default(cuid())
  email            String
  name             String?  // For new users, store the name from invitation
  token            String   @unique
  companyId        String
  expiresAt        DateTime
  isExistingUser   Boolean  @default(false)
  temporaryPassword String?
  used             Boolean  @default(false)
  usedAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([companyId])
}

// Enums converted to strings for SQLite compatibility
// UserRole: "ADMIN", "COMPANY_ADMIN", "EMPLOYEE", "INDIVIDUAL"
// VerificationMethod: "BUSINESS_REGISTRATION", "CREDIT_CHECK", "MANUAL_APPROVAL"
// InvoiceStatus: "PENDING", "PAID", "OVERDUE", "CANCELLED"
// QuestionType: "MULTIPLE_CHOICE", "TRUE_FALSE", "TEXT"
